# --- LLM (choose one) ---
# Amazon Bedrock (Converse API; same pattern as repo root temp.py). Takes precedence over OpenAI/Ollama.
# BEDROCK_REGION=eu-central-1
# BEDROCK_MODEL_ID=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# OpenAI (tool calling)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama / local OpenAI-compatible API (only if OPENAI_API_KEY is empty)
# Example: run `ollama serve` then `ollama pull llama3.2`
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# If BEDROCK_MODEL_ID, OPENAI_API_KEY and OLLAMA_BASE_URL are empty, the server uses
# deterministic demo answers (still loads semester JSON via NAT or fixture).

# --- NAT semester HTTP (optional) ---
# Basis-Host für /api/v1/semesters und /api/v1/semesters/{key} wenn kein Template gesetzt ist
# NAT_API_BASE_URL=https://api.srv.nat.tum.de
# NAT_SEMESTER_URL_TEMPLATE=https://api.srv.nat.tum.de/api/v1/semesters/{semester_key}

NAT_HTTP_TIMEOUT_S=20
USE_FIXTURE_IF_NAT_FAILS=true

# --- CampusPilot login (verschlüsselte Speicherung der TUM-/LRZ-Zugangsdaten) ---
# Für Produktion: starkes Geheimnis setzen und HTTPS nutzen (Cookie dann secure=true im Code anpassen).
# CAMPUSPILOT_SECRET=change-me-long-random
# Optional: fester Fernet-Schlüssel (44 Zeichen, url-safe base64), sonst Ableitung aus CAMPUSPILOT_SECRET
# CAMPUSPILOT_FERNET_KEY=
# CORS: Regex für Browser-Origins mit credentials (Vite-Default: localhost / 127.0.0.1 mit beliebigem Port)
# CORS_ALLOW_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1)(:\d+)?$

# Nach Login: TUMonline-Crawl (Playwright); nutzt dieselben Credentials wie /auth/login (users-Tabelle).
# Ergebnis landet in SQLite-Tabelle crawl_snapshots (gleiche Datei campuspilot_auth.db unter QandA_Agent/data/).
# CAMPUSPILOT_POST_LOGIN_CRAWL=0
#
# Playwright-Browser (einmal, im selben venv wie uvicorn — sonst "Executable doesn't exist"):
#   cd CampusPilot\QandA_Agent
#   .\.venv\Scripts\python.exe -m playwright install chromium
# Standard-Pfad: %LOCALAPPDATA%\ms-playwright\  (optional im Projekt: PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers)
# PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers
#
# --- TUMonline-Chat-Anmeldung (Playwright, siehe Agent/course_registration.py BASE_URL) ---
# Standard: KEINE schreibende Anmeldung (kein Klick auf „Belegwunsch erfassen“), damit echte Accounts
# nicht versehentlich irgendwo angemeldet werden. Suche + Anmelde-Infos funktionieren trotzdem.
# CAMPUSPILOT_TUM_REGISTRATION_EXECUTES_WRITES=true
#
# Zusätzlich: Wenn BASE_URL nicht demo.campus.tum.de ist, wird Anmeldung blockiert, bis:
# CAMPUSPILOT_TUM_REGISTRATION_ALLOW_NON_DEMO_HOST=true
# (nur setzen, wenn du bewusst gegen eine nicht-Demo-Instanz schreiben willst.)
#
# Merke: Mit demo.campus.tum.de betrifft Anmeldung nur die Demo — nicht die produktive TUMonline-Anmeldung.
# Echte LRZ-Zugangsdaten können trotzdem auf der Demo funktionieren; produktive Campus-URLs wären riskant.
#
# Semester-ID für Demo-Kurssuche (Agent/course_registration.py), falls die Demo ein anderes termId nutzt:
# TUMONLINE_TERM_ID=206

# Windows: Crawl läuft in einem Thread mit eigenem asyncio.run()+Proactor (campus_crawl).
